{{template "base/head" .}}
<style>
.ae-home { min-height: 100vh; background: #0a0a0f; display: flex; flex-direction: column; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
.ae-hero { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 24px 60px; text-align: center; position: relative; overflow: hidden; }
.ae-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(212,160,23,0.08) 0%, transparent 70%); pointer-events: none; }
.ae-wordmark { display: flex; align-items: center; gap: 14px; margin-bottom: 48px; }
.ae-wordmark svg { width: 44px; height: 44px; }
.ae-wordmark-text { font-size: 22px; font-weight: 600; color: #8b8fa8; letter-spacing: 0.08em; text-transform: uppercase; }
.ae-title { font-size: clamp(42px, 8vw, 80px); font-weight: 800; color: #f0f0f5; line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 20px; }
.ae-title span { background: linear-gradient(135deg, #d4a017 0%, #f5c842 50%, #d4a017 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ae-sub { font-size: 18px; color: #6b7280; max-width: 520px; line-height: 1.6; margin-bottom: 48px; }
.ae-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; margin-bottom: 80px; }
.ae-btn-primary { padding: 14px 36px; background: #d4a017; color: #0a0a0f; border-radius: 8px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.02em; transition: background 0.2s, transform 0.15s; }
.ae-btn-primary:hover { background: #f5c842; transform: translateY(-1px); }
.ae-btn-ghost { padding: 14px 36px; border: 1px solid #2a2a3a; color: #9ca3af; border-radius: 8px; font-size: 15px; font-weight: 500; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
.ae-btn-ghost:hover { border-color: #d4a017; color: #d4a017; }
.ae-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1px; background: #1a1a2a; max-width: 900px; width: 100%; border-radius: 16px; overflow: hidden; border: 1px solid #1a1a2a; }
.ae-card { background: #0f0f1a; padding: 32px 28px; }
.ae-card-icon { font-size: 28px; margin-bottom: 14px; }
.ae-card-title { font-size: 15px; font-weight: 700; color: #e5e7eb; margin-bottom: 8px; }
.ae-card-body { font-size: 13px; color: #6b7280; line-height: 1.6; }
.ae-footer { padding: 24px; text-align: center; border-top: 1px solid #1a1a2a; }
.ae-footer p { font-size: 12px; color: #374151; }
.ae-footer a { color: #d4a017; text-decoration: none; }
</style>
<div class="ae-home">
  <div class="ae-hero">
    <div class="ae-wordmark">
      <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="44" height="44" rx="10" fill="#d4a017"/>
        <path d="M22 8L36 34H8L22 8Z" fill="#0a0a0f"/>
        <circle cx="22" cy="30" r="4" fill="#d4a017"/>
      </svg>
      <span class="ae-wordmark-text">Agyeman Enterprises</span>
    </div>
    <h1 class="ae-title">The Code Forge.<br><span>Built for builders.</span></h1>
    <p class="ae-sub">AeGit is the sovereign development hub of Agyeman Enterprises — private infrastructure, full git hosting, and a platform that answers to no one but us.</p>
    <div class="ae-actions">
      <a href="{{AppSubUrl}}/user/login" class="ae-btn-primary">Sign In</a>
      <a href="{{AppSubUrl}}/explore/repos" class="ae-btn-ghost">Explore Repos</a>
    </div>
    <div class="ae-grid">
      <div class="ae-card">
        <div class="ae-card-icon">⚡</div>
        <div class="ae-card-title">Deployed by Srvrsup</div>
        <div class="ae-card-body">Running on AE infrastructure via the Srvrsup agent. No third-party PaaS. No lock-in.</div>
      </div>
      <div class="ae-card">
        <div class="ae-card-icon">🔒</div>
        <div class="ae-card-title">Sovereign by design</div>
        <div class="ae-card-body">Your code stays on AE servers. Full control over every byte, every permission, every policy.</div>
      </div>
      <div class="ae-card">
        <div class="ae-card-icon">🛠</div>
        <div class="ae-card-title">Full forge</div>
        <div class="ae-card-body">SSH + HTTPS git, issues, pull requests, code review, milestones — everything a team needs.</div>
      </div>
      <div class="ae-card">
        <div class="ae-card-icon">🌐</div>
        <div class="ae-card-title">GitHub mirrored</div>
        <div class="ae-card-body">All AE repos mirror here automatically. AeGit is the primary. GitHub is the backup.</div>
      </div>
    </div>
  </div>
  <div class="ae-footer">
    <p>AeGit &mdash; <a href="{{AppSubUrl}}">{{AppName}}</a> &mdash; Powered by <a href="{{AppSubUrl}}">Srvrsup</a> &bull; &copy; Agyeman Enterprises</p>
  </div>
</div>
{{template "base/footer" .}}
