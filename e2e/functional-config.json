      },
      {
        "action": "click",
        "target": "button[type=\"submit\"], button:has-text(\"Save\"), button:has-text(\"Create\"), button:has-text(\"Add\")",
        "description": "Submit create form"
      },
      {
        "action": "waitForText",
        "target": "E2E Test Dashboard",
        "description": "Dashboard appears in list"
      }
    ],
    "completionMarker": "E2E Test Dashboard"
